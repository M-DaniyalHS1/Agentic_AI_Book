# Vercel Production Environment Variables
# Add these in your Vercel Dashboard > Project Settings > Environment Variables
# ALL APIs ARE FREE: Groq (LLM) + HuggingFace (Embeddings) + Qdrant Cloud (Vector DB)

# ===========================================
# Required for Vercel Deployment
# ===========================================

# Qdrant Cloud (Sign up at https://cloud.qdrant.io - FREE 1GB tier)
QDRANT_URL=https://your-cluster.qdrant.tech
QDRANT_API_KEY=your-qdrant-api-key

# Groq API for LLM (Sign up at https://console.groq.com - FREE)
# Provides ultra-fast Llama model inference
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_MODEL=llama3-8b-8192

# HuggingFace API for Embeddings (Sign up at https://huggingface.co - FREE 30k requests/month)
HUGGINGFACE_API_KEY=hf_your-huggingface-key
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Database (Use Neon - FREE 0.5GB tier)
DATABASE_URL=postgresql://user:password@host:port/database

# CORS - Add your Vercel domain
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ===========================================
# Optional
# ===========================================
# LOG_LEVEL=INFO
# HUGGINGFACE_LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# ===========================================
# Authentication (Better Auth)
# ===========================================
# Better Auth Secret Key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
BETTER_AUTH_SECRET=your-better-auth-secret-key

# Gmail SMTP Configuration (for password reset emails)
# Create app password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_NAME=Agent Book Factory
SMTP_FROM_EMAIL=noreply@agent-book-factory.vercel.app

# Session Configuration
SESSION_EXPIRY_DAYS=7
SESSION_COOKIE_NAME=better-auth.session_token
