# Ignore backend Python dependencies in root
backend/venv/
backend/__pycache__/
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/

# Ignore frontend node_modules in root
frontend/node_modules/
frontend/.docusaurus/

# Ignore other large directories
ros_ws/
__pycache__/
.git/
.vercel/
.qwen/
history/
specs/
tests/

# Ignore environment files
.env
.env.local
.env.*.local

# Ignore IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Ignore logs and temp files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore Docker artifacts
docker-compose.yml
*.pid
*.seed
*.pid.lock

# IMPORTANT: Explicitly preserve api/ directory (negation pattern)
!api/
!api/**
