# Backend Environment Configuration
# Copy this file to .env and fill in your values
# FREE API Providers: Groq (LLM) + HuggingFace (Embeddings)

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
# For local development with Docker Compose
DATABASE_URL=postgresql://agentbook:agentbook_secret@localhost:5432/agent_book_db

# For production (e.g., Neon Serverless)
# DATABASE_URL=postgresql://user:password@host:port/database

# ===========================================
# Qdrant Vector Database
# ===========================================
# Local development
# QDRANT_URL=http://localhost:6333

# Production (REQUIRED for Vercel serverless - use Qdrant Cloud)
# Sign up at https://cloud.qdrant.io for free tier (1GB free)
QDRANT_URL=https://your-cluster.qdrant.tech
QDRANT_API_KEY=your-api-key-here

# ===========================================
# LLM Configuration - Groq (FREE)
# ===========================================
# Get FREE API key at https://console.groq.com
# Groq provides free access to Llama models with very fast inference
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama3-8b-8192

# Alternative: HuggingFace Inference API
# HUGGINGFACE_API_KEY=hf_your-key-here
# HUGGINGFACE_LLM_MODEL=meta-llama/Meta-Llama-3-8B-Instruct

# ===========================================
# Embedding Model Configuration - HuggingFace (FREE)
# ===========================================
# Get FREE API key at https://huggingface.co/settings/tokens
# Free tier: 30k requests/month
HUGGINGFACE_API_KEY=hf_your-huggingface-key-here
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Alternative embedding model (better quality)
# HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ===========================================
# RAG Configuration (Optional)
# ===========================================
# TOP_K_RESULTS=5
# SIMILARITY_THRESHOLD=0.7
# MAX_CONTEXT_TOKENS=4000
# MAX_RESPONSE_TOKENS=500

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
# For Vercel production, include your Vercel domain:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://your-app.vercel.app

# ===========================================
# Application Settings
# ===========================================
# ENVIRONMENT=development
# LOG_LEVEL=INFO
