{
  "buildCommand": "bash vercel_build.sh",
  "outputDirectory": "frontend/build",
  "devCommand": "cd frontend && npm run start",
  "installCommand": "bash vercel_install.sh",
  "functions": {
    "api/*.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
