# Frontend Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# API Configuration
# ===========================================
# For local development
REACT_APP_API_URL=http://localhost:8000

# For Vercel full-stack deployment:
# Leave empty or comment out to use relative URLs (API and frontend on same domain)
# REACT_APP_API_URL=

# For separate backend deployment (Railway/Render)
# REACT_APP_API_URL=https://your-api.railway.app

# ===========================================
# Feature Flags (Optional)
# ===========================================
# REACT_APP_ENABLE_ANALYTICS=false
# REACT_APP_ENABLE_OFFLINE_MODE=true

# ===========================================
# UI Configuration (Optional)
# ===========================================
# REACT_APP_CHAT_WIDGET_POSITION=bottom-right
# REACT_APP_MAX_MESSAGE_LENGTH=2000
